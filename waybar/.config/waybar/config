{
    "layer": "top",
    "position": "top",
    "height": 36,
    "margin-top": 6,
    "margin-left": 10,
    "margin-right": 10,
    "spacing": 0,

    "modules-left": [
        "sway/workspaces",
        "sway/mode",
        "custom/media"
    ],
    "modules-center": [
        "clock"
    ],
    "modules-right": [
        "wireplumber",
        "backlight",
        "network",
        "cpu",
        "memory",
        "temperature",
        "battery",
        "tray",
        "custom/power"
    ],

    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "format": "{icon}",
        "format-icons": {
            "1": "󰆍",
            "2": "󰈹",
            "3": "󰅩",
            "4": "󰓇",
            "5": "󰙯",
            "urgent": "󰀦",
            "focused": "󰄲",
            "default": "󰄯"
        }
    },

    "sway/mode": {
        "format": " {}"
    },

    "custom/media": {
        "format": "{icon} {}",
        "return-type": "json",
        "max-length": 35,
        "format-icons": {
            "spotify": "󰓇",
            "default": "󰎆"
        },
        "escape": true,
        "exec": "$HOME/.dotfiles/scripts/mediaplayer.sh 2>/dev/null",
        "on-click": "playerctl play-pause"
    },

    "clock": {
        "interval": 60,
        "format": "󱑒 {:%H:%M  󰃭 %a %d/%m}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode": "month",
            "weeks-pos": "right",
            "on-scroll": 1,
            "format": {
                "months":   "<span color='#ff9e64'><b>{}</b></span>",
                "days":     "<span color='#c0caf5'>{}</span>",
                "weeks":    "<span color='#7dcfff'><b>W{}</b></span>",
                "weekdays": "<span color='#bb9af7'><b>{}</b></span>",
                "today":    "<span color='#1a1b26' background='#7aa2f7'><b>{}</b></span>"
            }
        },
        "actions": {
            "on-click-right": "mode",
            "on-scroll-up": "shift_up",
            "on-scroll-down": "shift_down"
        }
    },

    "wireplumber": {
        "format": "{icon} {volume}%",
        "format-muted": "󰝟",
        "format-icons": ["󰕿", "󰖀", "󰕾"],
        "on-click": "pavucontrol",
        "on-click-right": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "tooltip-format": "{node_name}"
    },

    "backlight": {
        "format": "{icon} {percent}%",
        "format-icons": ["󰃞", "󰃟", "󰃠"],
        "on-scroll-up": "brightnessctl set 5%+",
        "on-scroll-down": "brightnessctl set 5%-",
        "tooltip": false
    },

    "network": {
        "interval": 5,
        "format-wifi": "󰖩 {essid}",
        "format-ethernet": "󰈀 {ifname}",
        "format-linked": "󰈀 {ifname} (no IP)",
        "format-disconnected": "󰖪",
        "tooltip-format-wifi": "{essid}  {signalStrength}%\n{ipaddr}",
        "tooltip-format-ethernet": "{ifname}\n{ipaddr}",
        "on-click": "nm-connection-editor"
    },

    "cpu": {
        "interval": 5,
        "format": "󰍛 {usage}%",
        "tooltip-format": "CPU: {usage}%\nLoad: {load}",
        "on-click": "ghostty -e btop"
    },

    "memory": {
        "interval": 10,
        "format": "󰘚 {percentage}%",
        "tooltip-format": "Used: {used:0.1f}G / {total:0.1f}G",
        "on-click": "ghostty -e btop"
    },

    "temperature": {
        "interval": 5,
        "critical-threshold": 80,
        "format": "{icon} {temperatureC}°C",
        "format-critical": "󱗗 {temperatureC}°C",
        "format-icons": ["󰔄", "󰔏", "󱗗"],
        "tooltip": false
    },

    "battery": {
        "interval": 30,
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": "󱐋 {capacity}%",
        "format-plugged": "󰚥 {capacity}%",
        "format-full": "󰁹 Full",
        "format-icons": ["󰂎", "󰁺", "󰁻", "󰁼", "󰁽", "󰁾", "󰁿", "󰂀", "󰂁", "󰂂", "󰁹"],
        "tooltip-format": "{timeTo}\nCycles: {cycles}"
    },

    "tray": {
        "icon-size": 16,
        "spacing": 8
    },

    "custom/power": {
        "format": "󰐥",
        "tooltip": false,
        "on-click": "~/.dotfiles/scripts/powermenu.sh"
    }
}
