{
    "layer": "top",
    "position": "top",
    "height": 50,
    "margin-top": 6,
    "margin-left": 10,
    "margin-right": 10,
    "spacing": 0,

    "modules-left": [
        "sway/workspaces",
        "sway/mode",
        "custom/media"
    ],
    "modules-center": [
        "clock"
    ],
    "modules-right": [
        "custom/easyeffects",
        "wireplumber",
        "backlight",
        "network",
        "cpu",
        "memory",
        "temperature",
        "battery",
        "tray",
        "custom/power"
    ],

    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "format": "{icon}",
        "format-icons": {
            "1": "σΑÜç",
            "2": "σΑàΙ",
            "3": "σΑÖ©",
            "4": "σΑ™΅",
            "5": "σΑô·",
            "urgent": "σΑÄΠ",
            "focused": "σΑ³≤",
            "default": "σΑ³·"
        }
    },

    "sway/mode": {
        "format": " {}"
    },

    "custom/media": {
        "format": "{icon} {}",
        "return-type": "json",
        "max-length": 35,
        "format-icons": {
            "spotify": "σΑ™΅",
            "default": "σΑéÜ"
        },
        "escape": true,
        "exec": "$HOME/.dotfiles/scripts/mediaplayer.sh 2>/dev/null",
        "on-click": "playerctl play-pause"
    },

    "clock": {
        "interval": 60,
        "format": "σ±ë£ {:%H:%M  σΑÉ≠ %a %d/%m}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode": "month",
            "weeks-pos": "right",
            "on-scroll": 1,
            "format": {
                "months":   "<span color='#ff9e64'><b>{}</b></span>",
                "days":     "<span color='#c0caf5'>{}</span>",
                "weeks":    "<span color='#7dcfff'><b>W{}</b></span>",
                "weekdays": "<span color='#bb9af7'><b>{}</b></span>",
                "today":    "<span color='#1a1b26' background='#7aa2f7'><b>{}</b></span>"
            }
        },
        "actions": {
            "on-click-right": "mode",
            "on-scroll-up": "shift_up",
            "on-scroll-down": "shift_down"
        }
    },

    "wireplumber": {
        "format": "{icon} {volume}%",
        "format-muted": "σΑùü",
        "format-icons": ["σΑïΩ", "σΑ•Ä", "σΑïΨ"],
        "on-click": "pavucontrol",
        "on-click-right": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "tooltip-format": "{node_name}"
    },

    "backlight": {
        "device": "amdgpu_bl0",
        "format": "{icon} {percent}%",
        "format-icons": ["σΑÉû", "σΑÉü", "σΑÉ†"],
        "on-scroll-up": "brightnessctl set 5%+",
        "on-scroll-down": "brightnessctl set 5%-",
        "tooltip": false
    },

    "network": {
        "interval": 5,
        "format-wifi": "σΑ•© {essid}",
        "format-ethernet": "σΑàÄ {ifname}",
        "format-linked": "σΑàÄ {ifname} (no IP)",
        "format-disconnected": "σΑ•Σ",
        "tooltip-format-wifi": "{essid}  {signalStrength}%\n{ipaddr}",
        "tooltip-format-ethernet": "{ifname}\n{ipaddr}",
        "on-click": "nm-connection-editor"
    },

    "cpu": {
        "interval": 5,
        "format": "σΑç¦ {usage}%",
        "tooltip-format": "CPU: {usage}%\nLoad: {load}",
        "on-click": "ghostty -e btop"
    },

    "memory": {
        "interval": 10,
        "format": "σΑ‰ö {percentage}%",
        "tooltip-format": "Used: {used:0.1f}G / {total:0.1f}G",
        "on-click": "ghostty -e btop"
    },

    "temperature": {
        "interval": 5,
        "critical-threshold": 80,
        "format": "{icon} {temperatureC}¬ΑC",
        "format-critical": "σ±½½ {temperatureC}¬ΑC",
        "format-icons": ["σΑî³", "σΑîè", "σ±½½"],
        "tooltip": false
    },

    "battery": {
        "interval": 30,
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": "σ±ê΄ {capacity}%",
        "format-plugged": "σΑöΞ {capacity}%",
        "format-full": "σΑ¹Ι Full",
        "format-icons": ["σΑ²é", "σΑ¹Κ", "σΑ¹Μ", "σΑ¹Φ", "σΑ¹Ϋ", "σΑ¹Ψ", "σΑ¹Ω", "σΑ²Ä", "σΑ²¹", "σΑ²²", "σΑ¹Ι"],
        "tooltip-format": "{timeTo}\nCycles: {cycles}"
    },

    "tray": {
        "icon-size": 16,
        "spacing": 8
    },

    "custom/easyeffects": {
        "exec": "$HOME/.dotfiles/scripts/easyeffects-status.sh",
        "return-type": "json",
        "interval": 5,
        "on-click": "flatpak run com.github.wwmm.easyeffects",
        "on-click-right": "flatpak run com.github.wwmm.easyeffects --quit",
        "tooltip": true
    },

    "custom/power": {
        "format": "σΑêΞ",
        "tooltip": false,
        "on-click": "~/.dotfiles/scripts/powermenu.sh"
    }
}
