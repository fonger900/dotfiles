{
    "layer": "top",
    "position": "top",
    "height": 50,
    "margin-top": 6,
    "margin-left": 10,
    "margin-right": 10,
    "spacing": 0,
    "modules-left": [
        "sway/workspaces",
        "sway/mode",
        "custom/media"
    ],
    "modules-center": [
        "clock"
    ],
    "modules-right": [
        "group/utils",
        "group/hardware",
        "group/connections",
        "group/stats",
        "battery",
        "tray",
        "custom/power"
    ],
    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "format": "{icon}",
        "format-icons": {
            "1": "َ°†چ",
            "2": "َ°–ں",
            "3": "َ° ®",
            "4": "َ°‡®",
            "5": "َ°“‡",
            "6": "َ°™¯",
            "7": "َ°–²",
            "8": "َ°ٹ—",
            "9": "َ°“”",
            "10": "َ°گ¥",
            "urgent": "َ°€¦",
            "focused": "َ°„²",
            "default": "َ°„¯"
        }
    },
    "sway/mode": {
        "format": " {}"
    },
    "custom/media": {
        "format": "{icon} {}",
        "return-type": "json",
        "max-length": 35,
        "format-icons": {
            "spotify": "َ°“‡",
            "default": "َ°ژ†"
        },
        "escape": true,
        "exec": "$HOME/.dotfiles/scripts/mediaplayer.sh 2>/dev/null",
        "on-click": "playerctl play-pause"
    },
    "clock": {
        "interval": 60,
        "format": "َ±‘’ {:%H:%M  َ°ƒ­ %a %d/%m}",
        "tooltip-format": "<tt>{calendar}</tt>",
        "calendar": {
            "mode": "month",
            "mode-mon-col": 3,
            "weeks-pos": "right",
            "on-scroll": 1,
            "format": {
                "months": "<span color='#ff9e64'><b>{}</b></span>",
                "days": "<span color='#c0caf5'><b>{}</b></span>",
                "weeks": "<span color='#7dcfff'><b>W{}</b></span>",
                "weekdays": "<span color='#bb9af7'><b>{}</b></span>",
                "today": "<span color='#1a1b26' background='#ff9e64'><b>{}</b></span>"
            }
        },
        "actions": {
            "on-click-right": "mode",
            "on-scroll-up": "shift_up",
            "on-scroll-down": "shift_down"
        }
    },
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-bluetooth": "{icon}ïٹ” {volume}%",
        "format-bluetooth-muted": "َ°‌ںïٹ”",
        "format-muted": "َ°‌ں",
        "format-icons": {
            "headphone": "َ°‹‹",
            "hands-free": "َ°‹ژ",
            "headset": "َ°‹ژ",
            "phone": "ï‚•",
            "portable": "ï‚•",
            "car": "ï†¹",
            "default": [
                "َ°•؟",
                "َ°–€",
                "َ°•¾"
            ]
        },
        "on-click": "pavucontrol",
        "on-click-right": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "tooltip-format": "{desc}"
    },
    "bluetooth": {
        "format": "ïٹ”",
        "format-disabled": "َ°‚²",
        "format-off": "َ°‚²",
        "format-connected": "َ°‚±",
        "format-connected-battery": "َ°‚± {device_battery_percentage}%",
        "tooltip-format": "{controller_alias}\t{controller_address}\n\n{num_connections} connected",
        "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{num_connections} connected\n\n{device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
        "tooltip-format-enumerate-connected-battery": "{device_alias}\t{device_address}\t{device_battery_percentage}%",
        "on-click": "blueman-manager"
    },
    "backlight": {
        "device": "amdgpu_bl0",
        "format": "{icon} {percent}%",
        "format-icons": [
            "َ°ƒ‍",
            "َ°ƒں",
            "َ°ƒ "
        ],
        "on-scroll-up": "brightnessctl set 5%+",
        "on-scroll-down": "brightnessctl set 5%-",
        "tooltip": false
    },
    "network": {
        "interval": 5,
        "format-wifi": "َ°–© {essid}",
        "format-ethernet": "َ°ˆ€ {ifname}",
        "format-linked": "َ°ˆ€ {ifname} (no IP)",
        "format-disconnected": "َ°–ھ",
        "tooltip-format-wifi": "{essid}  {signalStrength}%\n{ipaddr}",
        "tooltip-format-ethernet": "{ifname}\n{ipaddr}",
        "on-click": "nm-connection-editor"
    },
    "cpu": {
        "interval": 5,
        "format": "َ°چ› {usage}%",
        "tooltip-format": "CPU: {usage}%\nLoad: {load}",
        "on-click": "wezterm -e btop"
    },
    "memory": {
        "interval": 10,
        "format": "َ°کڑ {percentage}%",
        "tooltip-format": "Used: {used:0.1f}G / {total:0.1f}G",
        "on-click": "wezterm -e btop"
    },
    "temperature": {
        "interval": 5,
        "critical-threshold": 80,
        "format": "{icon} {temperatureC}آ°C",
        "format-critical": "َ±—— {temperatureC}آ°C",
        "format-icons": [
            "َ°”„",
            "َ°”ڈ",
            "َ±——"
        ],
        "tooltip": false
    },
    "battery": {
        "interval": 30,
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": "َ±گ‹ {capacity}%",
        "format-plugged": "َ°ڑ¥ {capacity}%",
        "format-full": "َ°پ¹ Full",
        "format-icons": [
            "َ°‚ژ",
            "َ°پ؛",
            "َ°پ»",
            "َ°پ¼",
            "َ°پ½",
            "َ°پ¾",
            "َ°پ؟",
            "َ°‚€",
            "َ°‚پ",
            "َ°‚‚",
            "َ°پ¹"
        ],
        "tooltip-format": "{timeTo}\nCycles: {cycles}"
    },
    "tray": {
        "icon-size": 18,
        "spacing": 10
    },
    "group/utils": {
        "orientation": "horizontal",
        "modules": [
            "idle_inhibitor",
            "custom/gamemode",
            "custom/keepassxc",
            "custom/easyeffects"
        ]
    },
    "custom/gamemode": {
        "exec": "gamemoded -s | grep -q 'is active' && echo '{\"text\":\"َ°““\",\"class\":\"active\",\"tooltip\":\"Gamemode: Active\"}' || echo '{\"text\":\"َ°““\",\"class\":\"inactive\",\"tooltip\":\"Gamemode: Inactive\"}'",
        "return-type": "json",
        "interval": 10
    },
    "group/hardware": {
        "orientation": "horizontal",
        "modules": [
            "pulseaudio",
            "backlight"
        ]
    },
    "group/connections": {
        "orientation": "horizontal",
        "modules": [
            "network",
            "bluetooth"
        ]
    },
    "group/stats": {
        "orientation": "horizontal",
        "drawer": {
            "transition-duration": 500,
            "transition-left-to-right": false
        },
        "modules": [
            "cpu",
            "memory",
            "temperature"
        ]
    },

    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "َ°…¶",
            "deactivated": "َ°›‘"
        },
        "tooltip-format-activated": "Stay Awake: Auto-sleep is disabled",
        "tooltip-format-deactivated": "Auto Sleep: System follows normal idle timers"
    },
    "custom/easyeffects": {
        "exec": "$HOME/.dotfiles/scripts/easyeffects-status.sh",
        "return-type": "json",
        "interval": 5,
        "on-click": "$HOME/.dotfiles/scripts/easyeffects-toggle.sh",
        "on-click-right": "$HOME/.dotfiles/scripts/easyeffects-toggle.sh --quit",
        "tooltip": true
    },
    "custom/power": {
        "format": "َ°گ¥",
        "tooltip": false,
        "on-click": "~/.dotfiles/scripts/powermenu.sh"
    }
}