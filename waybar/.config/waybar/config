{
    "layer": "top",
    "position": "top",
    "height": 50,
    "margin-top": 6,
    "margin-left": 10,
    "margin-right": 10,
    "spacing": 0,

    "modules-left": [
        "sway/workspaces",
        "sway/mode",
        "custom/media"
    ],
    "modules-center": [
        "clock"
    ],
    "modules-right": [
        "custom/easyeffects",
        "pulseaudio",
        "backlight",
        "network",
        "bluetooth",
        "cpu",
        "memory",
        "temperature",
        "battery",
        "tray",
        "custom/power"
    ],

    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "format": "{icon}",
        "format-icons": {
            "1": "≤░ΗΞ",
            "2": "≤░Ι╣",
            "3": "≤░Ζσ",
            "4": "≤░ΥΘ",
            "5": "≤░βψ",
            "urgent": "≤░Αο",
            "focused": "≤░Ε▓",
            "default": "≤░Εψ"
        }
    },

    "sway/mode": {
        "format": " {}"
    },

    "custom/media": {
        "format": "{icon} {}",
        "return-type": "json",
        "max-length": 35,
        "format-icons": {
            "spotify": "≤░ΥΘ",
            "default": "≤░ΟΗ"
        },
        "escape": true,
        "exec": "$HOME/.dotfiles/scripts/mediaplayer.sh 2>/dev/null",
        "on-click": "playerctl play-pause"
    },

    "clock": {
        "interval": 60,
        "format": "≤▒ΣΤ {:%H:%M  ≤░Δφ %a %d/%m}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode": "month",
            "weeks-pos": "right",
            "on-scroll": 1,
            "format": {
                "months":   "<span color='#ff9e64'><b>{}</b></span>",
                "days":     "<span color='#c0caf5'>{}</span>",
                "weeks":    "<span color='#7dcfff'><b>W{}</b></span>",
                "weekdays": "<span color='#bb9af7'><b>{}</b></span>",
                "today":    "<span color='#1a1b26' background='#7aa2f7'><b>{}</b></span>"
            }
        },
        "actions": {
            "on-click-right": "mode",
            "on-scroll-up": "shift_up",
            "on-scroll-down": "shift_down"
        }
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-bluetooth": "{icon}ΎΛΦ {volume}%",
        "format-bluetooth-muted": "≤░ζθΎΛΦ",
        "format-muted": "≤░ζθ",
        "format-icons": {
            "headphone": "≤░ΜΜ",
            "hands-free": "≤░ΜΟ",
            "headset": "≤░ΜΟ",
            "phone": "ΎΓΧ",
            "portable": "ΎΓΧ",
            "car": "ΎΗ╣",
            "default": ["≤░Χ┐", "≤░ΨΑ", "≤░Χ╛"]
        },
        "on-click": "pavucontrol",
        "on-click-right": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "tooltip-format": "{desc}"
    },

    "bluetooth": {
        "format": "ΎΛΦ",
        "format-connected": "≤░Γ▒",
        "format-connected-battery": "≤░Γ▒ {device_battery_percentage}%",
        "tooltip-format": "{controller_alias}\t{controller_address}\n\n{num_connections} connected",
        "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{num_connections} connected\n\n{device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
        "tooltip-format-enumerate-connected-battery": "{device_alias}\t{device_address}\t{device_battery_percentage}%",
        "on-click": "blueman-manager"
    },

    "backlight": {
        "device": "amdgpu_bl0",
        "format": "{icon} {percent}%",
        "format-icons": ["≤░Δη", "≤░Δθ", "≤░Δι"],
        "on-scroll-up": "brightnessctl set 5%+",
        "on-scroll-down": "brightnessctl set 5%-",
        "tooltip": false
    },

    "network": {
        "interval": 5,
        "format-wifi": "≤░Ψσ {essid}",
        "format-ethernet": "≤░ΙΑ {ifname}",
        "format-linked": "≤░ΙΑ {ifname} (no IP)",
        "format-disconnected": "≤░Ψς",
        "tooltip-format-wifi": "{essid}  {signalStrength}%\n{ipaddr}",
        "tooltip-format-ethernet": "{ifname}\n{ipaddr}",
        "on-click": "nm-connection-editor"
    },

    "cpu": {
        "interval": 5,
        "format": "≤░Ξδ {usage}%",
        "tooltip-format": "CPU: {usage}%\nLoad: {load}",
        "on-click": "wezterm -e btop"
    },

    "memory": {
        "interval": 10,
        "format": "≤░αγ {percentage}%",
        "tooltip-format": "Used: {used:0.1f}G / {total:0.1f}G",
        "on-click": "wezterm -e btop"
    },

    "temperature": {
        "interval": 5,
        "critical-threshold": 80,
        "format": "{icon} {temperatureC}┬░C",
        "format-critical": "≤▒ΩΩ {temperatureC}┬░C",
        "format-icons": ["≤░ΦΕ", "≤░ΦΠ", "≤▒ΩΩ"],
        "tooltip": false
    },

    "battery": {
        "interval": 30,
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": "≤▒ΡΜ {capacity}%",
        "format-plugged": "≤░γξ {capacity}%",
        "format-full": "≤░Β╣ Full",
        "format-icons": ["≤░ΓΟ", "≤░Β║", "≤░Β╗", "≤░Β╝", "≤░Β╜", "≤░Β╛", "≤░Β┐", "≤░ΓΑ", "≤░ΓΒ", "≤░ΓΓ", "≤░Β╣"],
        "tooltip-format": "{timeTo}\nCycles: {cycles}"
    },

    "tray": {
        "icon-size": 16,
        "spacing": 8
    },

    "custom/easyeffects": {
        "exec": "$HOME/.dotfiles/scripts/easyeffects-status.sh",
        "return-type": "json",
        "interval": 5,
        "on-click": "$HOME/.dotfiles/scripts/easyeffects-toggle.sh",
        "on-click-right": "$HOME/.dotfiles/scripts/easyeffects-toggle.sh --quit",
        "tooltip": true
    },

    "custom/power": {
        "format": "≤░Ρξ",
        "tooltip": false,
        "on-click": "~/.dotfiles/scripts/powermenu.sh"
    }
}
