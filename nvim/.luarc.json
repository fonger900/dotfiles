{
  "runtime.version": "LuaJIT",
  "runtime.path": [
    "lua/?.lua",
    "lua/?/init.lua"
  ],
  "diagnostics.globals": [
    "vim",
    "it",
    "describe",
    "before_each",
    "after_each",
    "pending",
    "teardown",
    "setup"
  ],
  "workspace.library": [
    "$VIMRUNTIME/lua",
    "$VIMRUNTIME/lua/vim/lsp",
    "${3rd}/luv/library",
    "${3rd}/busted/library"
  ],
  "workspace.maxPreload": 100000,
  "workspace.preloadFileSize": 10000,
  "workspace.checkThirdParty": false,
  "completion.callSnippet": "Both",
  "completion.keywordSnippet": "Both",
  "hint.enable": true,
  "format.enable": true,
  "telemetry.enable": false
}