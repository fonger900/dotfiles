# General
set font "JetBrains Mono 12"
set page-padding 10
set scroll-step 50

# Recolor — sepia mode
set recolor "true"
set recolor-keephue "true"
set recolor-lightcolor "#f4ecd8"   # nền kem
set recolor-darkcolor "#433422"    # chữ nâu

# UI minimal
set statusbar-h-padding 10
set statusbar-v-padding 5
set default-bg "#f4ecd8"
set statusbar-bg "#e8dcc8"
set statusbar-fg "#433422"
set inputbar-bg "#e8dcc8"
set inputbar-fg "#433422"

# Behavior
set zoom-min 10
set guioptions ""              # ẩn thanh toolbar
set scroll-page-aware "true"
set smooth-scroll "true"