# --- Giao diện tối giản ---
set statusbar-h-padding 0
set statusbar-v-padding 0
set show-scrollbars false
set guioptions ""

# --- Màu sắc dễ chịu (Recolor) ---
# Nhấn Ctrl + R để bật/tắt chế độ này khi đọc đêm
set recolor "true"
set recolor-keephue "true"
set recolor-lightcolor "#1a1a1a" # Nền xám tối của ThinkPad
set recolor-darkcolor  "#dcdcdc" # Chữ xám sáng

# --- Cuộn chuột mượt hơn ---
set scroll-step 50
set scroll-full-overlap 0.01
set scroll-wrap true

# --- Tìm kiếm thông minh ---
set incremental-search true
set search-hadjust true

# --- Clipboard ---
# Tự động copy nội dung khi bôi đen (rất tiện để paste vào ghi chú)
set selection-clipboard clipboard
