# ==========================================
# Lynx Style Sheet (LSS)
# ==========================================

# Syntax: tag:attr:fg:bg
# Attributes: bold, blink, reverse, underline, dim, normal

# Basic elements
normal:normal:default:default
default:normal:default:default
em:bold:red:default
strong:bold:green:default
h1:bold:yellow:default
h2:bold:cyan:default
h3:bold:magenta:default

# Links and Interaction
a:bold:blue:default
img:normal:cyan:default
status:reverse:white:blue
label:normal:magenta:default
value:normal:white:default

# Forms
input:reverse:white:default
select:reverse:white:default
textarea:reverse:white:default

# Specific tags
blockquote:normal:cyan:default
cite:normal:magenta:default
code:normal:green:default
dd:normal:white:default
dt:bold:white:default
li:normal:white:default
ol:normal:white:default
ul:normal:white:default
pre:normal:green:default
table:normal:white:default
td:normal:white:default
th:bold:white:default
tr:normal:white:default
